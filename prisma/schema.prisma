generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum StockMovementType {
  IN
  OUT
}

model Company {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches       Branch[]
  products       Product[]
  stockBalances  StockBalance[]
  stockMovements StockMovement[]

  @@index([name])
}

model Branch {
  id        String   @id @default(cuid())
  companyId String
  name      String
  code      String?
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stockBalances  StockBalance[]
  stockMovements StockMovement[]

  @@unique([companyId, name])
  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, isActive])
}

model Product {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  barcode     String?
  sku         String?
  category    String
  unit        String   @default("unidad")
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stockBalances  StockBalance[]
  stockMovements StockMovement[]

  @@unique([companyId, barcode])
  @@unique([companyId, sku])
  @@index([companyId])
  @@index([companyId, isActive])
  @@index([companyId, name])
  @@index([companyId, category])
}

model StockBalance {
  id        String   @id @default(cuid())
  companyId String
  branchId  String
  productId String
  quantity  Decimal  @default(0) @db.Decimal(12, 3)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([companyId, branchId, productId])
  @@index([companyId])
  @@index([companyId, branchId])
  @@index([companyId, productId])
}

model StockMovement {
  id        String            @id @default(cuid())
  companyId String
  branchId  String
  productId String
  type      StockMovementType
  quantity  Decimal           @db.Decimal(12, 3)
  reason    String
  notes     String?
  createdAt DateTime          @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, branchId])
  @@index([companyId, productId])
  @@index([companyId, type])
  @@index([companyId, createdAt])
  @@index([companyId, branchId, createdAt])
}
